{
  "name": "nutridex",
  "version": "0.1.0",
  "private": true,
  "description": "NutriDex — a science-backed nutrition benefits database: teas, fruits, vegetables, meats, and nuts.",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:e2e": "playwright test",
    "content:validate": "tsx scripts/validate-content.ts",
    "citations:verify": "tsx scripts/verify-citations.ts",
    "usda:import": "tsx scripts/import-usda.ts",
    "usda:enrich": "tsx scripts/enrich-usda-api.ts",
    "research": "tsx scripts/research.ts",
    "blog:research": "tsx scripts/blog-research.ts",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "^16.2.10",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "next": "^16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "csv-parse": "^7.0.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.10",
    "postcss": "^8.5.16",
    "prettier": "^3.9.4",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.22.5",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
