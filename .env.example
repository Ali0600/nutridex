# Copy to .env.local (gitignored) and fill in. Never commit real keys.

# USDA FoodData Central / api.data.gov key — used ONLY by `npm run usda:enrich`
# (author-side nutrient import). Get a free key at https://fdc.nal.usda.gov/api-key-signup
# The app and CI never read this; nutrient data is committed as data/usda/nutrients.generated.json.
FDC_API_KEY=

# Optional: overrides the production site URL used for canonical/OG metadata.
# NEXT_PUBLIC_SITE_URL=https://nutridex-neon.vercel.app
